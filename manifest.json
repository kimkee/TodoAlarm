{
  "manifest_version": 3,
  "name": "할일 알리미 (TodoAlarm)",
  "version": "1.0.0",
  "description": "지정된 요일과 시간에 브라우저 알림을 띄워 주요 일정을 잊지 않도록 돕는 알림 서비스입니다.",
  "permissions": [
    "alarms",
    "notifications",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon128.png",
      "48": "icons/icon128.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon128.png",
    "48": "icons/icon128.png",
    "128": "icons/icon128.png"
  }
}
